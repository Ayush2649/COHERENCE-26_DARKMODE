# Copy to .env.local and fill in your keys.

# Required for AI Message Generator and campaign AI-generated emails
OPENAI_API_KEY=sk-your-openai-api-key-here

# Required to send real emails (Campaign Simulator → Send Email / Follow-up nodes)
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key-here

# Optional: "From" address for sent emails (default: Outreach <onboarding@resend.dev> for testing)
# For production, verify your domain at https://resend.com/domains and set e.g. Outreach <hello@yourdomain.com>
# RESEND_FROM=Outreach <onboarding@resend.dev>

# Optional: subject line for campaign emails (default: "Quick outreach")
# EMAIL_SUBJECT=Quick outreach
